NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/consultease

JWT_ACCESS_SECRET=replace-with-very-long-secret-32-chars-min
JWT_REFRESH_SECRET=replace-with-very-long-secret-32-chars-min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=dev-sender-id-or-email

SPARROW_TOKEN=your_sparrow_api_token
SPARROW_FROM=InfoSMS

STORAGE_PROVIDER=MINIO
STORAGE_BUCKET=consultease
STORAGE_SIGNED_URL_EXPIRES_SECONDS=1200
STORAGE_SIGNED_URL_MAX_EXPIRES_SECONDS=3600
STORAGE_MAX_FILE_SIZE_BYTES=15728640

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
